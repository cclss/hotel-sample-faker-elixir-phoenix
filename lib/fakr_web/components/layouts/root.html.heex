<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Fakr" suffix=" · Faker as a Service">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        // Copy to clipboard handler
        window.addEventListener("phx:copy", (e) => {
          const text = e.detail.text;
          navigator.clipboard.writeText(text).then(() => {
            // optional: show feedback
          });
        });
      })();
    </script>
  </head>
  <body class="bg-smoke/30 min-h-screen">
    <%!-- Top Navigation Bar --%>
    <nav class="bg-peppercorn text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2">
            <span class="text-cavendish font-bold text-xl">Fakr</span>
            <span class="text-gray-400 text-xs">Faker as a Service</span>
          </a>
          <div class="flex items-center gap-4">
            <.link navigate="/explore" class="text-sm text-gray-300 hover:text-white transition">
              Explore
            </.link>
            <%= if @current_scope do %>
              <.link
                navigate="/dashboard"
                class="text-sm text-gray-300 hover:text-white transition"
              >
                Dashboard
              </.link>
              <span class="text-sm text-gray-400">
                @{@current_scope.user.username}
              </span>
              <.link
                href={~p"/users/log-out"}
                method="delete"
                class="text-sm text-gray-300 hover:text-white transition"
              >
                Log out
              </.link>
            <% else %>
              <.link
                href={~p"/users/register"}
                class="text-sm text-gray-300 hover:text-white transition"
              >
                Register
              </.link>
              <.link
                href={~p"/users/log-in"}
                class="text-sm bg-cypress px-3 py-1.5 rounded-lg hover:bg-cypress/90 transition"
              >
                Log in
              </.link>
            <% end %>
          </div>
        </div>
      </div>
      <%!-- Cavendish accent stripe --%>
      <div class="h-1 bg-cavendish"></div>
    </nav>

    {@inner_content}
  </body>
</html>
