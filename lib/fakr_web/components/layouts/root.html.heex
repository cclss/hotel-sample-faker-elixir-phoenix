<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Fakr" suffix=" · Faker as a Service">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        // Copy to clipboard handler
        window.addEventListener("phx:copy", (e) => {
          const text = e.detail.text;
          navigator.clipboard.writeText(text).then(() => {
            // optional: show feedback
          });
        });
      })();
    </script>
  </head>
  <body class="bg-page-bg min-h-screen">
    <%!-- Top Navigation Bar --%>
    <nav class="bg-code-bg text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2">
            <span class="text-mint-light font-bold text-xl">Fakr</span>
            <span class="text-gray-400 text-xs">Faker as a Service</span>
          </a>
          <div class="flex items-center gap-4">
            <.link navigate="/explore" class="text-sm text-gray-300 hover:text-white transition">
              Explore
            </.link>
            <%= if @current_scope do %>
              <.link navigate="/dashboard" class="text-sm text-gray-300 hover:text-white transition">
                Dashboard
              </.link>
              <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-full bg-indigo/80 flex items-center justify-center text-[11px] font-bold text-white uppercase">
                  {String.first(@current_scope.user.username)}
                </div>
                <span class="text-sm text-gray-300">{@current_scope.user.username}</span>
              </div>
              <.link href={~p"/users/settings"} class="text-gray-400 hover:text-white transition" title="Settings">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
              </.link>
              <.link href={~p"/users/log-out"} method="delete" class="text-gray-400 hover:text-white transition" title="Log out">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                </svg>
              </.link>
            <% else %>
              <.link
                href={~p"/users/register"}
                class="text-sm text-gray-300 hover:text-white transition"
              >
                Register
              </.link>
              <.link
                href={~p"/users/log-in"}
                class="text-sm bg-indigo px-3 py-1.5 rounded-lg hover:bg-violet transition"
              >
                Log in
              </.link>
            <% end %>
          </div>
        </div>
      </div>
      <%!-- Gradient accent stripe --%>
      <div class="h-1 bg-gradient-to-r from-deep-violet via-indigo to-mint-light"></div>
    </nav>

    {@inner_content}
  </body>
</html>
